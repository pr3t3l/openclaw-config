      "min_narrative_words": 250,
      "min_exchanges": 12,
      "needs_image": false,
      "supports_audio": true,
      "audio_type": "911_call",
      "quality_floor": {
        "requirements": [
          "Visible emotional arc in caller",
          "Operator stays professional",
          "Timestamps present",
          "Key revelation moment occurs mid-call not at end",
          "Background sounds noted"
        ],
        "narrative_count_rule": "Count dialogue text only. Exclude speaker tags (**Operator:**) and timestamp markers ([00:01:23])."
      }
