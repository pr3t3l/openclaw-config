{
  "templates": {
    "1": {
      "type_id": 1,
      "type_key": "poi_sheet",
      "name": "POI Sheet / Suspect List",
      "html_template": "poi_sheet.html",
      "required_vars": [
        "caseNumber",
        "docId",
        "date",
        "classification",
        "caseTitle",
        "pois"
      ],
      "optional_vars": [
        "paperTexture"
      ],
      "pois_item_vars": [
        "title",
        "name",
        "dob",
        "height",
        "weight",
        "eyes",
        "hair",
        "status",
        "mugshot",
        "connection_to_case"
      ],
      "min_narrative_words": 50,
      "min_exchanges": null,
      "needs_image": true,
      "image_type": "mugshot",
      "image_count": "one_per_poi",
      "supports_audio": false,
      "quality_floor": {
        "requirements": [
          "All POI entries with photo reference",
          "Each POI has bio + case connection",
          "Status field filled for all"
        ],
        "narrative_count_rule": "Count only field VALUES (not labels). 'Height: 5\\'11\"' counts '5\\'11\"' only."
      }
    },
    "2": {
      "type_id": 2,
