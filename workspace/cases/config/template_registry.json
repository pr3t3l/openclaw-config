    "6": {
      "type_id": 6,
      "type_key": "transcript_911",
      "name": "911 Transcript",
      "html_template": "transcript_911.html",
      "required_vars": [
        "title",
        "caseNumber",
        "docId",
        "date",
        "classification",
        "agency",
